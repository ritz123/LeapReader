{
  "name": "leap-reader",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "main": "electron/main.mjs",
  "author": "Leap reader",
  "description": "Split-pane PDF reader with libraries, highlights, and notes.",
  "scripts": {
    "dev": "vite",
    "desktop": "vite --open",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "desktop:start": "electron .",
    "desktop:build": "npm run build && electron .",
    "start:desktop": "bash scripts/run-desktop.sh",
    "build:dist": "bash scripts/build-dist.sh",
    "test:appimage": "bash scripts/test-appimage.sh",
    "release": "bash scripts/release.sh",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "build:dist:appimage": "bash scripts/build-dist.sh AppImage",
    "build:dist:deb": "bash scripts/build-dist.sh deb",
    "pack:linux": "bash scripts/build-dist.sh",
    "build:android": "bash scripts/build-android.sh",
    "build:android:release": "bash scripts/build-android.sh release",
    "cap:sync": "cap sync",
    "cap:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.leapreader.app",
    "productName": "Leap reader",
    "executableName": "leap-reader",
    "copyright": "Copyright © Leap reader",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "synopsis": "Split-pane PDF reader with highlights and libraries",
      "maintainer": "Leap reader <noreply@localhost>",
      "icon": "build/icons/icon.png",
      "desktop": {
        "MimeType": "application/pdf;",
        "Keywords": "pdf;reader;document;"
      }
    },
    "deb": {
      "depends": []
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Leap Reader"
    }
  }
}
